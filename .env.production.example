# MultiTenantPlatform — Production Environment Variables
# Set these in Vercel dashboard → Project → Settings → Environment Variables

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:pass@db.<ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:pass@db.<ref>.supabase.co:5432/postgres
# SHADOW_DATABASE_URL not needed in production (only for local migration authoring)

# ── Supabase (auth + DB) ──────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-side only, never expose to browser

# ── Auth ──────────────────────────────────────────────────────────────────────
STATIC_OTP_ENABLED=false            # false = use Supabase real SMS
STATIC_OTP_ALLOW_IN_PRODUCTION=false
STATIC_OTP_SESSION_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
STATIC_OTP_ALLOWED_COUNTRIES=ZA
STATIC_OTP_ALLOWED_PHONE_PREFIXES=+27
STATIC_OTP_REQUIRE_E164=true
ADMIN_PHONE_ALLOWLIST=+27...        # comma-separated admin phone numbers

# ── Billing (set one PSP block) ───────────────────────────────────────────────
PAYMENT_PROVIDER=paystack           # paystack | payfast | fastspring

# Paystack (if PAYMENT_PROVIDER=paystack)
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# PayFast (if PAYMENT_PROVIDER=payfast)
# PAYFAST_MERCHANT_ID=...
# PAYFAST_MERCHANT_KEY=...
# PAYFAST_PASSPHRASE=...

# FastSpring (if PAYMENT_PROVIDER=fastspring)
# FASTSPRING_API_USER=...
# FASTSPRING_API_PASSWORD=...
# FASTSPRING_WEBHOOK_SECRET=...

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://<your-vercel-domain>.vercel.app
NODE_ENV=production
