{
  "name": "bms",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @bms/db migrate:dev",
    "db:seed": "pnpm --filter @bms/db seed",
    "db:reset": "pnpm --filter @bms/db migrate:reset"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "^5.7.2"
  }
}
